<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDisplayName</key>
	<string>walt.id</string>
	<key>NSCameraUsageDescription</key>
	<string>Camera access is required to scan QR codes for credential offers.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>id.walt.walletdemo</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>openid-credential-offer</string>
				<string>openid4vp</string>
			</array>
		</dict>
	</array>
	<!-- DEBUG ONLY: ATS exception for local E2E testing against enterprise on localhost -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>enterprise.localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
