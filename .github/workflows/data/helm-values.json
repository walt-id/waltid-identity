      "image": {
        "tag": "latest"
      }
    },
    "ingress": {
      "host": "wallet-api2.test.waltid.cloud",
      "clusterIssuer": "letsencrypt-prod",
      "tls": [
        {
          "secretName": "wallet-api2-tls-secret",
          "hosts": [
            "wallet-api2.test.waltid.cloud"
          ]
        }
      ]
    }
  },
  "web-wallet": {
    "configFiles": {
      "oidc.conf": "publicBaseUrl = \"https://wallet-dev.test.waltid.cloud\"\nproviderName = keycloak\noidcRealm = \"https://keycloak.walt-test.cloud/realms/waltid-keycloak-ktor\"\noidcJwks = \"${oidcRealm}/protocol/openid-connect/certs\"\nauthorizeUrl = \"${oidcRealm}/protocol/openid-connect/auth\"\naccessTokenUrl = \"${oidcRealm}/protocol/openid-connect/token\"\nlogoutUrl = \"${oidcRealm}/protocol/openid-connect/logout\"\nclientId = \"wallet_backend_prod\"\nclientSecret = \"__DEFAULT_KEYCLOAK_CLIENT_SECRET__\"\nkeycloakUserApi = \"https://keycloak.walt-test.cloud/admin/realms/waltid-keycloak-ktor/users\"\njwksCache = {\n    cacheSize = 10\n    cacheExpirationHours = 24\n    rateLimit: {\n        bucketSize: 10\n        refillRateMinutes: 1\n    }\n}"
    },
    "walletConfig": {
      "authConf": "encryptionKey = \"<128 bit -- key>\"\nsignKey = \"<128 bit -- key>\"\ntokenKey = \"<a - longer 256+ bit key or rsa private key in jwk format- here>\"\ntokenLifetime = \"30\"\naudTokenClaim = \"audience value\"\nissTokenClaim = \"issuer value\""
    },
    "web": {
      "credentialsRepository": {
        "host": "credentials.walt.id"
      },
      "devUi": {
        "host": "wallet-dev.test.waltid.cloud",
        "image": {
          "tag": "latest"
        }
      },
      "demoUi": {
        "host": "wallet.test.waltid.cloud",
        "image": {
          "tag": "latest"
        }
      }
    },
    "api": {
      "walletApi": {
        "image": {
          "tag": "latest"
        }
      }
    },
    "pvc": {
      "dataVolumeClaim": {
        "accessMode": "ReadWriteOnce",
        "storageClass": "gp3-retain"
      }
    },
    "ingress": {
      "clusterIssuer": "letsencrypt-prod",
      "tls": [
        {
          "secretName": "wallet-tls-secret",
          "hosts": [
            "wallet-dev.test.waltid.cloud",
            "wallet.test.waltid.cloud"
          ]
        }
      ]
    }
  }
}