VERSION_TAG=0.13.0-dev
VERSION_OPA=1.4.2
VERSION_VAULT=1.19.3

IMAGE_PREFIX=""
# IMAGE_PREFIX="docker.io/"

WALLET_BACKEND_PORT=7001
ISSUER_API_PORT=7002
VERIFIER_API_PORT=7003
DEMO_WALLET_FRONTEND_PORT=7101
WEB_PORTAL_PORT=7102
VC_REPO_PORT=7103
DEV_WALLET_FRONTEND_PORT=7104
VAULT_PORT=8200
OPA_SERVER_PORT=8181

# database
DB_NAME=waltid
DB_USERNAME=waltid
DB_PASSWORD=waltid

# sqlite
SQLITE_DB_DATA=data/data.db
# postgres
POSTGRES_DB_PORT=5432
POSTGRES_DB_DATA=/waltid-wallet-api/data/
PG_ADMIN_PORT=8080
# mssql
MSSQL_DB_PORT=1433

# sqlite | postgres | mssql
DATABASE_ENGINE=postgres

# endpoints
CREDENTIALS_REPOSITORY_URL=http://localhost:7103
ISSUER_CALLBACK_URL=http://localhost:7100
DEMO_WALLET_URL=http://localhost:7101
DEV_WALLET_URL=http://localhost:7104

# identity | identity,tse | identity,opa | all
COMPOSE_PROFILES=identity
